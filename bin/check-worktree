#!/usr/bin/env bash
# Enforces worktree-first development: blocks code-editing tools when running
# on the main branch. Orchestration tools (Bash, Read) are allowed so that
# /continue-pr and /finish-pr can be used from main.
# Called by .claude/settings.json PreToolUse hook.

branch=$(git branch --show-current 2>/dev/null)

if [ -z "$branch" ]; then
  echo "ERROR: Could not determine current git branch (detached HEAD or not a git repo)."
  echo "Please check out a branch before starting Claude Code."
  exit 1
fi

# Not on main — allow everything
[ "$branch" != "main" ] && exit 0

# On main — inspect the tool being called
tool_name=$(jq -r '.tool_name // ""')

case "$tool_name" in
  Edit|Write|NotebookEdit)
    echo "BLOCKED: Claude Code cannot edit files on the 'main' branch."
    echo ""
    echo "Each feature or fix requires its own worktree. Create one:"
    echo ""
    echo "  bin/worktree add <branch-name>"
    echo "  eval \"\$(bin/worktree cd <branch-name>)\""
    echo "  claude"
    echo ""
    echo "To see existing worktrees:"
    echo "  bin/worktree list"
    exit 1
    ;;
  *)
    # Bash, Read, Agent, and MCP tools are allowed for orchestration
    exit 0
    ;;
esac
