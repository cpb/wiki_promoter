# Copy this file to .env.local (gitignored) and fill in real values.
# .env.local is loaded automatically by `bundle exec rake` (see Rakefile) so
# `rake wiki:publish` etc. can pick up secrets without exporting them by hand.

# RubyGems API key. Only used by .github/workflows/release.yml to `gem push`
# when a `v*` tag is pushed — not read locally by anything in this repo.
# Create one at https://rubygems.org/profile/edit under "API Keys" (scope: push
# rubygem), then add it as a GitHub Actions repo secret named RUBYGEMS_API_KEY.
RUBYGEMS_API_KEY=

# Classic GitHub PAT with `repo` scope, used to push to a repo's wiki (the
# default GITHUB_TOKEN cannot write to a repo's wiki). Required to run
# `wiki-promoter publish` / `rake wiki:publish` locally, and must also be
# added as a GitHub Actions repo secret named WIKI_DEPLOY_TOKEN for the
# composite action.
WIKI_DEPLOY_TOKEN=

# Optional overrides for local wiki:publish/migrate runs (see README for the
# full list). Uncomment as needed.
# WIKI_REPOSITORY=cpb/wiki_promoter.wiki
# WIKI_BRANCH=master
# ENTRY_PAGE_NAME=
